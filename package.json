{
  "name": "infracost",
  "displayName": "Infracost",
  "description": "Cloud cost estimates for Terraform in your editor",
  "version": "0.3.8",
  "publisher": "Infracost",
  "license": "Apache-2.0",
  "icon": "infracost-logo.png",
  "engines": {
    "vscode": "^1.75.0"
  },
  "categories": [
    "Other",
    "Formatters",
    "Linters"
  ],
  "keywords": [
    "devops",
    "terraform",
    "hcl"
  ],
  "extensionDependencies": [],
  "repository": {
    "type": "git",
    "url": "https://github.com/infracost/vscode-infracost.git"
  },
  "activationEvents": [
    "onLanguage:terraform",
    "onLanguage:yaml",
    "onLanguage:json",
    "onLanguage:hcl"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "infracost",
          "title": "Infracost",
          "icon": "resources/icon.svg"
        }
      ]
    },
    "views": {
      "infracost": [
        {
          "type": "webview",
          "id": "infracost.resourceDetails",
          "name": "Resource Details"
        }
      ]
    },
    "configuration": {
      "title": "Infracost",
      "properties": {
        "infracost.serverPath": {
          "type": "string",
          "default": "",
          "description": "Path to the lsp binary. Leave empty to use the bundled binary."
        },
        "infracost.debug": {
          "type": "boolean",
          "default": false,
          "description": "Enable debug mode. Logs LSP trace output."
        },
        "infracost.debugUI": {
          "type": "string",
          "default": "",
          "description": "Host and port for the debug UI server (e.g. \":7100\")."
        },
        "infracost.enableDiagnostics": {
          "type": "boolean",
          "default": true,
          "description": "Show FinOps and tag policy violations as inline diagnostics (squiggly lines and Problems panel)."
        },
        "infracost.runParamsCacheTTLSeconds": {
          "type": "number",
          "default": 300,
          "description": "How long (in seconds) to cache run parameters (org ID, tag policies) between API calls. Set to 0 to disable caching."
        },
        "infracost.trace.server": {
          "type": "string",
          "enum": [
            "off",
            "messages",
            "verbose"
          ],
          "default": "off",
          "description": "Trace communication between VS Code and the Infracost language server."
        }
      }
    },
    "languages": [
      {
        "id": "terraform",
        "extensions": [
          ".tf"
        ],
        "aliases": [
          "Terraform"
        ]
      }
    ],
    "commands": [
      {
        "command": "infracost.login",
        "title": "Infracost: Login"
      },
      {
        "command": "infracost.restartLsp",
        "title": "Infracost: Restart Language Server"
      }
    ]
  },
  "scripts": {
    "vscode:package": "vsce package",
    "vscode:prepublish": "npm run package",
    "compile": "webpack",
    "watch": "webpack --watch",
    "package": "webpack --mode production --devtool hidden-source-map",
    "lint": "eslint src --ext ts,js --ignore-path .eslintignore --ignore-path .gitignore . --max-warnings=0",
    "lint:fix": "eslint src --fix --ext ts,js --ignore-path .eslintignore --ignore-path .gitignore . ",
    "format": "prettier --write 'src/**/*.{js,ts}'",
    "format:check": "prettier --check 'src/**/*.{js,ts}'"
  },
  "devDependencies": {
    "@types/node": "25.x",
    "@types/vscode": "^1.75.0",
    "@typescript-eslint/eslint-plugin": "^5.59.9",
    "@typescript-eslint/parser": "^5.59.1",
    "@vscode/vsce": "^3.7.1",
    "eslint": "^8.40.0",
    "eslint-config-airbnb-base": "^15.0.0",
    "eslint-config-prettier": "^8.8.0",
    "eslint-plugin-import": "^2.26.0",
    "eslint-plugin-prettier": "^4.2.1",
    "ovsx": "^0.10.9",
    "prettier": "^2.8.8",
    "ts-loader": "^9.4.2",
    "typescript": "^5.0.4",
    "webpack": "^5.77.0",
    "webpack-cli": "^5.0.2"
  },
  "dependencies": {
    "flatted": "^3.4.2",
    "vscode-languageclient": "^9.0.1",
    "vscode-languageserver-protocol": "^3.17.5"
  }
}
